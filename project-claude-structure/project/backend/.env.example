# ============================================
# AMAUTA - Configuración de Desarrollo
# ============================================
# Copia este archivo a .env y completa los valores
# NO hagas commit de tu .env real
# ============================================

# --- SUPABASE ---
# Obtén estos valores de tu proyecto Supabase > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- BASE DE DATOS ---
# Connection pooling (para runtime) - Supabase Dashboard > Connection Pooling
DATABASE_URL="postgresql://postgres.your_project:your_password@aws-1-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa (para migraciones/seed)
DIRECT_URL="postgresql://postgres.your_project:your_password@aws-1-your-region.pooler.supabase.com:5432/postgres"

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development