{
  "name": "@amauta/backend",
  "version": "1.0.0",
  "description": "API backend for Amauta exam simulator MVP",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "prisma": "^5.6.0",
    "@prisma/client": "^5.6.0",
    "winston": "^3.11.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.8.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.8",
    "@types/supertest": "^2.0.16",
    "tsx": "^4.1.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "ts-jest": "^29.1.1"
  },
  "keywords": [
    "api",
    "express",
    "supabase",
    "prisma",
    "exam-simulator",
    "mvp"
  ],
  "author": "Amauta Team",
  "license": "MIT"
}