# ============================================
# AMAUTA Mobile - Configuración Local
# ============================================
# Copia este archivo a .env.local y personalízalo
# NO hagas commit de tu .env.local real
# ============================================

# API del backend (cambia según tu red)
# Si el backend está en tu PC: usa tu IP local (ipconfig | grep IPv4)
# Si el backend está en un servidor: usa esa IP/puerto
API_URL=http://TU_IP_LOCAL:3000/api/v1

# Ejemplos de IPs comunes:
# API_URL=http://192.168.1.100:3000/api/v1
# API_URL=http://192.168.100.126:3000/api/v1